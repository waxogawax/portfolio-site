---
interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
const siteName = 'waxogawa';
const fullTitle = title === siteName ? title : `${title} — ${siteName}`;
const currentPath = Astro.url.pathname;
---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description ?? ''} />
    <title>{fullTitle}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500&family=Noto+Serif+JP:wght@400;500&display=swap" rel="stylesheet" />
  </head>
  <body>
    <header class="site-header">
      <div class="container">
        <a href="/" class="site-title">{siteName}</a>
        <nav class="site-nav" aria-label="メインナビゲーション">
          <a href="/exhibitions/" class:list={['nav-link', { active: currentPath.startsWith('/exhibitions') }]}>Exhibitions</a>
          <a href="/writings/" class:list={['nav-link', { active: currentPath.startsWith('/writings') }]}>Writings</a>
          <a href="/works/" class:list={['nav-link', { active: currentPath.startsWith('/works') }]}>Works</a>
          <span class="nav-divider" aria-hidden="true"></span>
          <a href="/diary/" class:list={['nav-link', { active: currentPath.startsWith('/diary') }]}>Diary</a>
          <a href="/research/" class:list={['nav-link', { active: currentPath.startsWith('/research') }]}>Research</a>
          <a href="/about/" class:list={['nav-link', { active: currentPath.startsWith('/about') }]}>About</a>
        </nav>
      </div>
    </header>

    <main class="site-main">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container">
        <p>&copy; {new Date().getFullYear()} {siteName}</p>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  /* ── Reset & Base ── */
  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  :root {
    --color-bg:        #e6e7e8;
    --color-text:      #0000ff;
    --color-muted:     #5555aa;
    --color-accent:    #000099;
    --color-neon:      #ffff00;
    --color-border:    #c4c6c8;
    --color-hover-bg:  #dadcdd;

    --font-sans:   'Inter', system-ui, sans-serif;
    --font-serif:  'Noto Serif JP', Georgia, serif;

    --width-site:    1040px;
    --width-article: 720px;
    --pad-h:         clamp(24px, 5vw, 64px);

    --transition: 0.18s ease;
  }

  html {
    background-color: var(--color-bg);
    color: var(--color-text);
    font-family: var(--font-sans);
    font-size: 16px;
    line-height: 1.8;
    -webkit-font-smoothing: antialiased;
  }

  a {
    color: inherit;
    text-decoration: none;
    transition: color var(--transition);
  }

  img {
    display: block;
    max-width: 100%;
  }

  /* ── Container ── */
  .container {
    max-width: var(--width-site);
    margin-inline: auto;
    padding-inline: var(--pad-h);
  }

  /* ── Header ── */
  .site-header {
    border-bottom: 1px solid var(--color-border);
    padding-block: 20px;
    position: sticky;
    top: 0;
    background-color: var(--color-bg);
    z-index: 10;
  }

  .site-header .container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }

  .site-title {
    font-family: var(--font-sans);
    font-size: 0.95rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: lowercase;
    color: var(--color-text);
    transition: color var(--transition);
  }

  .site-title:hover {
    color: var(--color-text);
  }

  /* ── Nav ── */
  .site-nav {
    display: flex;
    align-items: center;
    gap: 22px;
  }

  .nav-divider {
    display: block;
    width: 1px;
    height: 12px;
    background-color: var(--color-border);
  }

  .nav-link {
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-muted);
    transition: color var(--transition);
    position: relative;
  }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 0;
    height: 2px;
    background-color: var(--color-neon);
    transition: width var(--transition);
  }

  .nav-link:hover {
    color: var(--color-text);
  }

  .nav-link:hover::after,
  .nav-link.active::after {
    width: 100%;
  }

  .nav-link.active {
    color: var(--color-text);
  }

  /* ── Main ── */
  .site-main {
    min-height: calc(100vh - 180px);
    padding-block: 72px;
  }

  /* ── Footer ── */
  .site-footer {
    border-top: 1px solid var(--color-border);
    padding-block: 32px;
    margin-top: 80px;
  }

  .site-footer p {
    font-size: 0.8rem;
    color: var(--color-muted);
    letter-spacing: 0.04em;
  }

  /* ── Page heading ── */
  .page-heading {
    max-width: var(--width-site);
    margin-inline: auto;
    padding-inline: var(--pad-h);
    padding-bottom: 48px;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 56px;
  }

  .page-heading h1 {
    font-family: var(--font-sans);
    font-size: clamp(1.6rem, 3vw, 2.4rem);
    font-weight: 500;
    letter-spacing: -0.01em;
    line-height: 1.2;
  }

  .page-heading p {
    margin-top: 12px;
    font-size: 0.9rem;
    color: var(--color-muted);
  }

  /* ── Diary list ── */
  .diary-list {
    max-width: var(--width-site);
    margin-inline: auto;
    padding-inline: var(--pad-h);
    list-style: none;
  }

  .diary-item {
    display: grid;
    grid-template-columns: 120px 1fr;
    gap: 0 24px;
    align-items: baseline;
    padding-block: 20px;
    border-bottom: 1px solid var(--color-border);
    transition: background-color var(--transition);
  }

  .diary-item:first-child {
    border-top: none;
  }

  .diary-item:hover {
    background-color: var(--color-hover-bg);
    margin-inline: -12px;
    padding-inline: 12px;
  }

  .diary-date {
    font-size: 0.78rem;
    color: var(--color-muted);
    letter-spacing: 0.04em;
    font-variant-numeric: tabular-nums;
    padding-top: 2px;
  }

  .diary-content {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .diary-title-link {
    font-size: 1rem;
    font-weight: 400;
    color: var(--color-text);
    transition: color var(--transition);
    line-height: 1.4;
  }

  .diary-title-link:hover {
    color: var(--color-accent);
  }

  .diary-description {
    font-size: 0.82rem;
    color: var(--color-muted);
    line-height: 1.5;
  }

  /* ── Works grid ── */
  .works-grid {
    max-width: var(--width-site);
    margin-inline: auto;
    padding-inline: var(--pad-h);
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 40px 32px;
  }

  .works-card {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: 24px;
    border: 1px solid var(--color-border);
    background-color: #fff;
    transition: border-color var(--transition), transform var(--transition), box-shadow var(--transition);
  }

  .works-card:hover {
    border-color: var(--color-accent);
    transform: translateY(-2px);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.07);
  }

  .works-card-title {
    font-size: 1rem;
    font-weight: 500;
    color: var(--color-text);
    line-height: 1.3;
    transition: color var(--transition);
  }

  .works-card:hover .works-card-title {
    color: var(--color-accent);
  }

  .works-card-date {
    font-size: 0.75rem;
    color: var(--color-muted);
    letter-spacing: 0.04em;
    font-variant-numeric: tabular-nums;
  }

  .works-card-description {
    font-size: 0.85rem;
    color: var(--color-muted);
    line-height: 1.6;
  }

  .works-card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: auto;
    padding-top: 8px;
  }

  .tag {
    font-size: 0.7rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-muted);
    border: 1px solid var(--color-border);
    padding: 2px 8px;
    transition: border-color var(--transition), color var(--transition);
  }

  .works-card:hover .tag {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  /* ── Article ── */
  .article-container {
    max-width: var(--width-article);
    margin-inline: auto;
    padding-inline: var(--pad-h);
  }

  .article-meta {
    margin-bottom: 40px;
  }

  .article-back {
    display: inline-block;
    font-size: 0.8rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-muted);
    margin-bottom: 32px;
    transition: color var(--transition);
  }

  .article-back:hover {
    color: var(--color-accent);
  }

  .article-title {
    font-family: var(--font-serif);
    font-size: clamp(1.5rem, 3vw, 2.2rem);
    font-weight: 500;
    line-height: 1.3;
    letter-spacing: -0.01em;
    margin-bottom: 16px;
  }

  .article-date {
    font-size: 0.8rem;
    color: var(--color-muted);
    letter-spacing: 0.04em;
  }

  .article-description {
    margin-top: 12px;
    font-size: 0.95rem;
    color: var(--color-muted);
    line-height: 1.7;
  }

  .article-body {
    border-top: 1px solid var(--color-border);
    padding-top: 40px;
    font-family: var(--font-serif);
    font-size: 1rem;
    line-height: 1.9;
  }

  .article-body p {
    margin-bottom: 1.6em;
  }

  .article-body h2 {
    font-size: 1.2rem;
    font-weight: 500;
    margin-top: 2.4em;
    margin-bottom: 0.8em;
  }

  .article-body h3 {
    font-size: 1rem;
    font-weight: 500;
    margin-top: 2em;
    margin-bottom: 0.6em;
  }

  .article-body a {
    color: var(--color-accent);
    text-decoration: underline;
    text-decoration-color: transparent;
    transition: text-decoration-color var(--transition);
  }

  .article-body a:hover {
    text-decoration-color: var(--color-accent);
  }

  .article-body code {
    font-size: 0.85em;
    background: var(--color-hover-bg);
    padding: 0.1em 0.4em;
    border-radius: 2px;
  }

  .article-body pre {
    background: var(--color-hover-bg);
    padding: 20px;
    overflow-x: auto;
    margin-block: 1.6em;
    font-size: 0.85rem;
    line-height: 1.6;
  }

  .article-body blockquote {
    border-left: 2px solid var(--color-accent);
    padding-left: 20px;
    color: var(--color-muted);
    margin-block: 1.6em;
  }

  /* ── Home ── */
  .home-container {
    max-width: var(--width-site);
    margin-inline: auto;
    padding-inline: var(--pad-h);
    position: relative;
  }

  .home-intro {
    padding-bottom: 48px;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 40px;
  }

  .home-intro h1 {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 5vw, 3.4rem);
    font-weight: 400;
    line-height: 1.2;
    letter-spacing: -0.02em;
    margin-bottom: 20px;
  }

  .home-intro p {
    font-size: 0.95rem;
    color: var(--color-muted);
    max-width: 520px;
    line-height: 1.8;
  }

  /* ── Exhibitions list ── */
  .exh-list {
    max-width: var(--width-site);
    margin-inline: auto;
    padding-inline: var(--pad-h);
    list-style: none;
  }

  .exh-item {
    display: grid;
    grid-template-columns: 72px 1fr;
    gap: 0 24px;
    align-items: start;
    padding-block: 28px;
    border-bottom: 1px solid var(--color-border);
    transition: background-color var(--transition);
  }

  .exh-item:hover {
    background-color: var(--color-hover-bg);
    margin-inline: -12px;
    padding-inline: 12px;
  }

  .exh-item-year {
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    color: var(--color-muted);
    font-variant-numeric: tabular-nums;
    padding-top: 3px;
  }

  .exh-item-body {
    display: flex;
    flex-direction: column;
    gap: 5px;
  }

  .exh-item-type {
    font-size: 0.68rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent);
    font-weight: 500;
  }

  .exh-item-title {
    font-size: 1.05rem;
    font-weight: 400;
    color: var(--color-text);
    line-height: 1.35;
    transition: color var(--transition);
  }

  .exh-item:hover .exh-item-title {
    color: var(--color-accent);
  }

  .exh-item-venue {
    font-size: 0.82rem;
    color: var(--color-muted);
    line-height: 1.4;
  }

  .exh-item-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 5px;
    margin-top: 4px;
  }

  /* ── Exhibition detail ── */
  .exh-wide {
    max-width: var(--width-site);
    margin-inline: auto;
    padding-inline: var(--pad-h);
  }

  .exh-narrow {
    max-width: var(--width-article);
    margin-inline: auto;
    padding-inline: var(--pad-h);
  }

  .exh-header {
    max-width: var(--width-article);
    margin-inline: auto;
    padding-inline: var(--pad-h);
    margin-bottom: 48px;
  }

  .exh-title {
    font-family: var(--font-serif);
    font-size: clamp(1.6rem, 3.5vw, 2.6rem);
    font-weight: 500;
    line-height: 1.2;
    letter-spacing: -0.01em;
    margin-bottom: 28px;
  }

  .exh-meta-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 16px 24px;
    padding: 24px 0;
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .exh-meta-item {
    display: flex;
    flex-direction: column;
    gap: 3px;
  }

  .exh-meta-label {
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-muted);
  }

  .exh-meta-value {
    font-size: 0.88rem;
    color: var(--color-text);
    line-height: 1.4;
  }

  .exh-cover {
    max-width: var(--width-site);
    margin-inline: auto;
    padding-inline: var(--pad-h);
    margin-block: 56px;
  }

  .exh-cover img {
    width: 100%;
    max-height: 600px;
    object-fit: cover;
  }

  .exh-description {
    font-size: 1.05rem;
    color: var(--color-muted);
    line-height: 1.8;
    margin-bottom: 48px;
    padding-bottom: 48px;
    border-bottom: 1px solid var(--color-border);
  }

  .exh-section {
    margin-bottom: 64px;
  }

  .exh-section-label {
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-muted);
    margin-bottom: 24px;
    padding-bottom: 10px;
    border-bottom: 1px solid var(--color-border);
  }

  .exh-concept {
    font-family: var(--font-serif);
    font-size: 1rem;
    line-height: 1.95;
    color: var(--color-text);
  }

  .exh-concept p {
    margin-bottom: 1.6em;
  }

  .exh-concept p:last-child {
    margin-bottom: 0;
  }

  /* ── Gallery ── */
  .exh-gallery-section {
    max-width: var(--width-site);
    margin-inline: auto;
    padding-inline: var(--pad-h);
    margin-bottom: 64px;
  }

  .exh-gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 2px;
  }

  .exh-gallery-item {
    position: relative;
    overflow: hidden;
    background-color: var(--color-border);
    aspect-ratio: 4 / 3;
  }

  .exh-gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .exh-gallery-item:hover img {
    transform: scale(1.02);
  }

  .exh-gallery-caption {
    font-size: 0.75rem;
    color: var(--color-muted);
    margin-top: 8px;
    line-height: 1.4;
  }

  /* ── Links & Press ── */
  .exh-links-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .exh-link-item a {
    font-size: 0.9rem;
    color: var(--color-text);
    display: inline-flex;
    align-items: center;
    gap: 6px;
    transition: color var(--transition);
  }

  .exh-link-item a::after {
    content: '↗';
    font-size: 0.75em;
    color: var(--color-muted);
  }

  .exh-link-item a:hover {
    color: var(--color-accent);
  }

  .exh-press-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .exh-press-item {
    display: flex;
    flex-direction: column;
    gap: 3px;
  }

  .exh-press-title {
    font-size: 0.9rem;
    color: var(--color-text);
    transition: color var(--transition);
  }

  .exh-press-title:hover {
    color: var(--color-accent);
  }

  .exh-press-meta {
    font-size: 0.75rem;
    color: var(--color-muted);
  }

  .exh-instagram-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 0.88rem;
    color: var(--color-text);
    padding: 10px 0;
    transition: color var(--transition);
  }

  .exh-instagram-link:hover {
    color: var(--color-accent);
  }

  .exh-instagram-link::before {
    content: '◎';
    font-size: 0.75em;
    color: var(--color-muted);
  }

  /* ── Related ── */
  .exh-related-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .exh-related-item a {
    font-size: 0.88rem;
    color: var(--color-muted);
    transition: color var(--transition);
  }

  .exh-related-item a:hover {
    color: var(--color-accent);
  }

  /* ── Responsive ── */
  @media (max-width: 600px) {
    .diary-item {
      grid-template-columns: 1fr;
      gap: 4px;
    }

    .diary-item:hover {
      margin-inline: -8px;
      padding-inline: 8px;
    }

    .works-grid {
      grid-template-columns: 1fr;
    }

    .site-nav {
      gap: 10px;
      flex-wrap: wrap;
    }

    .nav-divider {
      display: none;
    }

    .exh-item {
      grid-template-columns: 48px 1fr;
      gap: 0 16px;
    }

    .exh-item:hover {
      margin-inline: -8px;
      padding-inline: 8px;
    }

    .exh-meta-grid {
      grid-template-columns: 1fr 1fr;
    }

    .exh-gallery-grid {
      grid-template-columns: 1fr;
    }
  }

  /* ── Reduced motion ── */
  @media (prefers-reduced-motion: reduce) {
    *,
    *::before,
    *::after {
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
    }
  }
</style>
