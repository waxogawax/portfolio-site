---
import BaseLayout from '../layouts/BaseLayout.astro';
import TuringField from '../components/TuringField.astro';
---

<BaseLayout title="waxogawa" description="展示、批評、制作のための個人アーカイブ">

  <TuringField />

  <!-- z-index: 1 keeps content above the canvas (position:relative set in BaseLayout) -->
  <div class="home-container" style="z-index: 1;">

    <section class="home-intro">
      <h1>waxogawa</h1>
      <p>
        展示、批評、研究、制作の記録。<br />
        デザインと言語のあいだで考え、作ることを続けています。
      </p>
    </section>

    <nav class="home-index" aria-label="コンテンツ一覧">
      <a href="/exhibitions/" class="index-item">Exhibitions</a>
      <a href="/writings/"   class="index-item">Writings</a>
      <a href="/works/"      class="index-item">Works</a>
      <a href="/diary/"      class="index-item">Diary</a>
      <a href="/research/"   class="index-item">Research</a>
      <a href="/about/"      class="index-item">About</a>
    </nav>

  </div>
</BaseLayout>

<style>
  /* ── Index grid ── */
  .home-index {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    border-top: 1px solid var(--color-border);
  }

  .index-item {
    display: flex;
    align-items: center;
    padding: 30px 24px;
    color: var(--color-text);
    text-decoration: none;
    font-size: clamp(0.92rem, 1.5vw, 1.08rem);
    font-weight: 500;
    letter-spacing: 0.01em;
    border-bottom: 1px solid var(--color-border);
    position: relative;
    isolation: isolate;
  }

  .index-item:nth-child(3n + 1) { padding-left: 0; }

  .index-item:not(:nth-child(3n + 1)) {
    border-left: 1px solid var(--color-border);
  }

  /* ── Self hover: Turing activator + diffusion front ── */

  /* Activator glow: concentrated, grows in 3.5 s */
  .index-item::after {
    content: '';
    position: absolute;
    inset: -10px -40px;
    background: radial-gradient(ellipse at 50% 50%, var(--color-neon) 0%, transparent 68%);
    opacity: 0;
    transform: scale(0.3, 0.2);
    filter: blur(20px);
    border-radius: 60% 40% 55% 45% / 50% 60% 40% 55%;
    pointer-events: none;
    z-index: -1;
    /* fast exit */
    transition: opacity 0.28s ease, transform 0.28s ease, filter 0.28s ease;
  }

  /* Diffusion front: wider, bleeds into neighbours */
  .index-item::before {
    content: '';
    position: absolute;
    inset: -32px -64px;
    background: radial-gradient(ellipse at 50% 50%, var(--color-neon) 0%, transparent 60%);
    opacity: 0;
    transform: scale(0.2, 0.15);
    filter: blur(36px);
    pointer-events: none;
    z-index: -1;
    /* fast exit */
    transition: opacity 0.28s ease, transform 0.28s ease, filter 0.28s ease;
  }

  /* Self hover: animation takes over (slow grow, fast exit) */
  .index-item:hover::after {
    animation: slime-activate 3.5s cubic-bezier(0.04, 0, 0.1, 1) forwards;
    transition: none;
  }
  .index-item:hover::before {
    animation: slime-diffuse 5s cubic-bezier(0.04, 0, 0.08, 1) 0.5s both;
    transition: none;
  }

  @keyframes slime-activate {
    0%   { opacity: 0.07; transform: scale(0.3,  0.20); filter: blur(22px); border-radius: 60% 40% 55% 45% / 50% 60% 40% 55%; }
    18%  { opacity: 0.15; transform: scale(0.62, 0.49); filter: blur(18px); }
    45%  { opacity: 0.20; transform: scale(0.97, 0.82); filter: blur(15px); border-radius: 44% 56% 48% 52% / 56% 44% 52% 48%; }
    100% { opacity: 0.27; transform: scale(1.52, 1.32); filter: blur(12px); border-radius: 50% 50% 44% 56% / 46% 54% 55% 45%; }
  }

  @keyframes slime-diffuse {
    0%   { opacity: 0;    transform: scale(0.20, 0.15); filter: blur(40px); border-radius: 50% 50% 50% 50%; }
    25%  { opacity: 0.05; transform: scale(0.57, 0.43); filter: blur(37px); }
    100% { opacity: 0.14; transform: scale(1.62, 1.44); filter: blur(26px); border-radius: 55% 45% 48% 52% / 52% 48% 44% 56%; }
  }

  /* ── Neighbour reaction: subsequent siblings respond to hover ──
     CSS can only target subsequent siblings (+, ~), not previous ones.
     The diffusion front's large negative inset handles the spatial bleed
     into visually adjacent cells regardless of DOM order.

     Entry transition is taken from the *destination* state (spec §3).
     Exit transition reverts to base state's 0.28 s (fast collapse).
  ── */

  /* All subsequent siblings: faint reaction field */
  .index-item:hover ~ .index-item::after {
    opacity: 0.05;
    transform: scale(0.65, 0.48);
    filter: blur(26px);
    /* slow entry — simulates diffusion lag */
    transition: opacity 1.4s ease-out, transform 1.4s ease-out, filter 1.2s ease-out;
  }
  .index-item:hover ~ .index-item::before {
    opacity: 0.03;
    transform: scale(0.50, 0.38);
    filter: blur(34px);
    transition: opacity 1.8s ease-out, transform 1.8s ease-out, filter 1.6s ease-out;
  }

  /* Direct right neighbour: stronger, faster reaction */
  .index-item:hover + .index-item::after {
    opacity: 0.09;
    transform: scale(0.82, 0.62);
    filter: blur(22px);
    transition: opacity 0.9s ease-out, transform 0.9s ease-out, filter 0.8s ease-out;
  }
  .index-item:hover + .index-item::before {
    opacity: 0.05;
    transform: scale(0.62, 0.48);
    filter: blur(30px);
    transition: opacity 1.2s ease-out, transform 1.2s ease-out, filter 1.0s ease-out;
  }

  /* ── Responsive ── */
  @media (max-width: 600px) {
    .home-index { grid-template-columns: 1fr; }
    .index-item { padding: 22px 0; border-left: none !important; }
  }
</style>
