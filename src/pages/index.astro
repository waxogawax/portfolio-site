---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="waxogawa" description="展示、批評、制作のための個人アーカイブ">
  <div class="home-container">

    <section class="home-intro">
      <h1>waxogawa</h1>
      <p>
        展示、批評、研究、制作の記録。<br />
        デザインと言語のあいだで考え、作ることを続けています。
      </p>
    </section>

    <nav class="home-index" aria-label="コンテンツ一覧">
      <a href="/exhibitions/" class="index-item">Exhibitions</a>
      <a href="/writings/"   class="index-item">Writings</a>
      <a href="/works/"      class="index-item">Works</a>
      <a href="/diary/"      class="index-item">Diary</a>
      <a href="/research/"   class="index-item">Research</a>
      <a href="/about/"      class="index-item">About</a>
    </nav>

  </div>
</BaseLayout>

<style>
  /* ── Index grid ── */
  .home-index {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    border-top: 1px solid var(--color-border);
  }

  .index-item {
    display: flex;
    align-items: center;
    padding: 30px 24px;
    color: var(--color-text);
    text-decoration: none;
    font-size: clamp(0.92rem, 1.5vw, 1.08rem);
    font-weight: 500;
    letter-spacing: 0.01em;
    border-bottom: 1px solid var(--color-border);
    position: relative;
    isolation: isolate;
  }

  /* first column: flush-left */
  .index-item:nth-child(3n + 1) {
    padding-left: 0;
  }

  /* column dividers */
  .index-item:not(:nth-child(3n + 1)) {
    border-left: 1px solid var(--color-border);
  }

  /* ── Activator glow (::after)
     Turing activator: concentrated, bright, grows in 3.5 s
  ── */
  .index-item::after {
    content: '';
    position: absolute;
    inset: -8px -32px;
    background: radial-gradient(ellipse at 50% 50%, var(--color-neon) 0%, transparent 68%);
    opacity: 0;
    transform: scale(0.3, 0.2);
    filter: blur(20px);
    border-radius: 60% 40% 55% 45% / 50% 60% 40% 55%;
    pointer-events: none;
    z-index: -1;
    /* fast exit when hover leaves */
    transition: opacity 0.28s ease, transform 0.28s ease, filter 0.28s ease;
  }

  /* ── Diffusion front (::before)
     Turing inhibitor: wider, dimmer, delayed, bleeds into neighbors
  ── */
  .index-item::before {
    content: '';
    position: absolute;
    inset: -28px -56px;
    background: radial-gradient(ellipse at 50% 50%, var(--color-neon) 0%, transparent 60%);
    opacity: 0;
    transform: scale(0.2, 0.15);
    filter: blur(36px);
    pointer-events: none;
    z-index: -1;
    transition: opacity 0.28s ease, transform 0.28s ease, filter 0.28s ease;
  }

  /* hover: animation takes over from transition for slow growth */
  .index-item:hover::after {
    animation: slime-activate 3.5s cubic-bezier(0.04, 0, 0.1, 1) forwards;
    transition: none;
  }

  /* diffusion starts 0.5 s after activation — "both" covers the delay window */
  .index-item:hover::before {
    animation: slime-diffuse 5s cubic-bezier(0.04, 0, 0.08, 1) 0.5s both;
    transition: none;
  }

  /* activator: bright core spreads asymmetrically */
  @keyframes slime-activate {
    0% {
      opacity: 0.06;
      transform: scale(0.3, 0.2);
      filter: blur(22px);
      border-radius: 60% 40% 55% 45% / 50% 60% 40% 55%;
    }
    18% {
      opacity: 0.13;
      transform: scale(0.62, 0.49);
      filter: blur(19px);
    }
    45% {
      opacity: 0.18;
      transform: scale(0.97, 0.82);
      filter: blur(16px);
      border-radius: 44% 56% 48% 52% / 56% 44% 52% 48%;
    }
    100% {
      opacity: 0.23;
      transform: scale(1.48, 1.28);
      filter: blur(13px);
      border-radius: 50% 50% 44% 56% / 46% 54% 55% 45%;
    }
  }

  /* diffusion: wider, dimmer, bleeds into neighbors */
  @keyframes slime-diffuse {
    0% {
      opacity: 0;
      transform: scale(0.2, 0.15);
      filter: blur(40px);
      border-radius: 50% 50% 50% 50%;
    }
    25% {
      opacity: 0.04;
      transform: scale(0.57, 0.43);
      filter: blur(38px);
    }
    100% {
      opacity: 0.11;
      transform: scale(1.58, 1.40);
      filter: blur(28px);
      border-radius: 55% 45% 48% 52% / 52% 48% 44% 56%;
    }
  }

  /* ── Responsive ── */
  @media (max-width: 600px) {
    .home-index {
      grid-template-columns: 1fr;
    }

    .index-item {
      padding: 22px 0;
      border-left: none !important;
    }
  }
</style>
