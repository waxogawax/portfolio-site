---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="waxogawa" description="展示、批評、制作のための個人アーカイブ">
  <div class="home-container">

    <div class="home-blobs" aria-hidden="true">
      <div class="blob blob--a"></div>
      <div class="blob blob--b"></div>
    </div>

    <section class="home-intro">
      <h1>waxogawa</h1>
      <p class="home-statement">
        展示、批評、研究、制作の記録。<br />
        デザインと言語のあいだで考え、作ることを続けています。
      </p>
    </section>

    <div class="home-primary">
      <section class="home-section">
        <h2>Exhibitions</h2>
        <a href="/exhibitions/" class="home-section-link">展示記録を見る →</a>
      </section>

      <section class="home-section">
        <h2>Writings</h2>
        <a href="/writings/" class="home-section-link">テキストを見る →</a>
      </section>

      <section class="home-section">
        <h2>Works</h2>
        <a href="/works/" class="home-section-link">作品一覧を見る →</a>
      </section>
    </div>

    <div class="home-secondary">
      <section class="home-section home-section--secondary">
        <h2>Diary</h2>
        <a href="/diary/" class="home-section-link">日記を見る →</a>
      </section>

      <section class="home-section home-section--secondary">
        <h2>Research</h2>
        <a href="/research/" class="home-section-link">研究情報を見る →</a>
      </section>

      <section class="home-section home-section--secondary">
        <h2>About</h2>
        <a href="/about/" class="home-section-link">プロフィールを見る →</a>
      </section>
    </div>

  </div>
</BaseLayout>

<style>
  /* ── Blobs ── */
  .home-blobs {
    position: absolute;
    inset: -80px -60px;
    overflow: hidden;
    pointer-events: none;
    z-index: 0;
  }

  .blob {
    position: absolute;
    border-radius: 60% 40% 30% 70% / 60% 30% 70% 40%;
  }

  .blob--a {
    width: 520px;
    height: 420px;
    background: #e5ff00;
    opacity: 0.08;
    top: -60px;
    left: -120px;
    animation: blob-morph-a 30s ease-in-out infinite;
  }

  .blob--b {
    width: 360px;
    height: 480px;
    background: #6b6b67;
    opacity: 0.055;
    top: 40px;
    right: -80px;
    border-radius: 40% 60% 55% 45% / 65% 35% 60% 40%;
    animation: blob-morph-b 38s ease-in-out infinite;
  }

  @keyframes blob-morph-a {
    0%, 100% {
      border-radius: 60% 40% 30% 70% / 60% 30% 70% 40%;
      transform: translate(0, 0);
    }
    25% {
      border-radius: 40% 60% 55% 45% / 40% 65% 35% 60%;
      transform: translate(18px, -12px);
    }
    50% {
      border-radius: 30% 60% 70% 40% / 50% 55% 30% 60%;
      transform: translate(8px, 22px);
    }
    75% {
      border-radius: 55% 45% 40% 60% / 65% 30% 65% 35%;
      transform: translate(-12px, 6px);
    }
  }

  @keyframes blob-morph-b {
    0%, 100% {
      border-radius: 40% 60% 55% 45% / 65% 35% 60% 40%;
      transform: translate(0, 0);
    }
    33% {
      border-radius: 60% 40% 40% 60% / 40% 65% 35% 60%;
      transform: translate(-14px, 18px);
    }
    66% {
      border-radius: 50% 50% 35% 65% / 55% 40% 65% 35%;
      transform: translate(10px, -14px);
    }
  }

  /* ── Intro ── */
  .home-statement {
    font-family: var(--font-serif);
    font-size: 1rem;
    color: var(--color-muted);
    max-width: 480px;
    line-height: 1.9;
  }

  /* ── Layer ordering ── */
  .home-intro,
  .home-primary,
  .home-secondary {
    position: relative;
    z-index: 1;
  }

  /* ── Primary grid ── */
  .home-primary {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 40px;
    margin-bottom: 64px;
  }

  .home-primary .home-section h2 {
    font-size: clamp(1rem, 1.8vw, 1.3rem);
    color: var(--color-text);
    border-bottom: none;
    padding-bottom: 0;
    margin-bottom: 14px;
    padding-left: 10px;
    border-left: 2px solid var(--color-neon);
  }

  /* ── Section hover ── */
  .home-section {
    padding: 14px;
    margin: -14px;
    border-radius: 2px;
    transition: background-color var(--transition), transform var(--transition);
  }

  .home-section:hover {
    background-color: rgba(229, 255, 0, 0.05);
    transform: translateY(-2px);
  }

  /* ── Secondary grid ── */
  .home-secondary {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 32px;
    padding-top: 40px;
    border-top: 1px solid var(--color-border);
  }

  .home-section--secondary h2 {
    font-size: 0.78rem;
  }

  .home-section--secondary .home-section-link {
    font-size: 0.83rem;
  }

  .home-section--secondary:hover {
    background-color: rgba(107, 107, 103, 0.04);
    transform: translateY(-1px);
  }
</style>
