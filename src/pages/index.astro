---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="waxogawa" description="展示、批評、制作のための個人アーカイブ">
  <div class="home-container">

    <section class="home-intro">
      <h1>waxogawa</h1>
      <p>
        展示、批評、研究、制作の記録。<br />
        デザインと言語のあいだで考え、作ることを続けています。
      </p>
    </section>

    <div class="home-index">

      <div class="home-primary">
        <a href="/exhibitions/" class="index-item">
          <span class="index-item-name">Exhibitions</span>
          <span class="index-item-sub">展示記録</span>
        </a>
        <a href="/writings/" class="index-item">
          <span class="index-item-name">Writings</span>
          <span class="index-item-sub">批評・エッセイ・テキスト</span>
        </a>
        <a href="/works/" class="index-item">
          <span class="index-item-name">Works</span>
          <span class="index-item-sub">作品一覧</span>
        </a>
      </div>

      <div class="home-secondary">
        <a href="/diary/" class="index-item-sm">Diary</a>
        <a href="/research/" class="index-item-sm">Research</a>
        <a href="/about/" class="index-item-sm">About</a>
      </div>

    </div>

  </div>
</BaseLayout>

<style>
  /* ── Primary index ── */
  .home-primary {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0 2px;
    border-top: 1px solid var(--color-border);
    margin-bottom: 0;
  }

  .index-item {
    display: flex;
    flex-direction: column;
    gap: 7px;
    padding: 28px 0 28px 0;
    color: var(--color-text);
    text-decoration: none;
    position: relative;
    isolation: isolate;
    transition: color var(--transition);
  }

  .index-item:not(:first-child) {
    padding-left: 28px;
    border-left: 1px solid var(--color-border);
  }

  /* seeping glow — organic spread on hover */
  .index-item::after {
    content: '';
    position: absolute;
    inset: 12px -12px;
    background: var(--color-neon);
    opacity: 0;
    border-radius: 60% 40% 50% 50% / 50% 50% 40% 60%;
    filter: blur(24px);
    transform: scaleX(0.45) scaleY(0.25);
    transition:
      opacity 0.55s cubic-bezier(0.22, 1, 0.36, 1),
      transform 0.55s cubic-bezier(0.22, 1, 0.36, 1),
      filter 0.45s ease,
      border-radius 0.65s ease;
    pointer-events: none;
    z-index: -1;
  }

  .index-item:hover::after {
    opacity: 0.14;
    transform: scaleX(1) scaleY(1);
    filter: blur(14px);
    border-radius: 45% 55% 45% 55% / 55% 45% 55% 45%;
  }

  .index-item-name {
    font-family: var(--font-sans);
    font-size: clamp(1rem, 2vw, 1.25rem);
    font-weight: 500;
    letter-spacing: -0.01em;
    line-height: 1.2;
    transition: color var(--transition);
  }

  .index-item:hover .index-item-name {
    color: var(--color-text);
  }

  .index-item-sub {
    font-size: 0.75rem;
    color: var(--color-muted);
    letter-spacing: 0.03em;
    line-height: 1.4;
    transition: color var(--transition);
  }

  /* ── Secondary index ── */
  .home-secondary {
    display: flex;
    gap: 0;
    border-top: 1px solid var(--color-border);
    padding-top: 0;
  }

  .index-item-sm {
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-muted);
    padding: 16px 20px 16px 0;
    text-decoration: none;
    position: relative;
    isolation: isolate;
    transition: color var(--transition);
  }

  .index-item-sm::after {
    content: '';
    position: absolute;
    inset: 6px -6px;
    background: var(--color-neon);
    opacity: 0;
    border-radius: 50%;
    filter: blur(14px);
    transform: scale(0.3);
    transition:
      opacity 0.45s cubic-bezier(0.22, 1, 0.36, 1),
      transform 0.45s cubic-bezier(0.22, 1, 0.36, 1),
      filter 0.35s ease;
    pointer-events: none;
    z-index: -1;
  }

  .index-item-sm:hover {
    color: var(--color-text);
  }

  .index-item-sm:hover::after {
    opacity: 0.1;
    transform: scale(1);
    filter: blur(8px);
  }

  /* ── Responsive ── */
  @media (max-width: 600px) {
    .home-primary {
      grid-template-columns: 1fr;
      gap: 0;
    }

    .index-item:not(:first-child) {
      padding-left: 0;
      border-left: none;
      border-top: 1px solid var(--color-border);
    }

    .home-secondary {
      flex-wrap: wrap;
      gap: 0 4px;
    }
  }
</style>
