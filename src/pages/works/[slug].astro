---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const entries = await getCollection('works', ({ data }) => {
    return data.draft !== true;
  });

  return entries.map((entry) => ({
    params: { slug: entry.id.replace(/\.md$/, '') },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<BaseLayout title={entry.data.title} description={entry.data.description}>
  <div class="article-container">
    <div class="article-meta">
      <a href="/works/" class="article-back">← Works</a>
      <h1 class="article-title">{entry.data.title}</h1>
      <time class="article-date" datetime={entry.data.date.toISOString()}>
        {entry.data.date.toLocaleDateString('ja-JP')}
      </time>
      {entry.data.description && (
        <p class="article-description">{entry.data.description}</p>
      )}
      {entry.data.tags.length > 0 && (
        <div class="works-card-tags" style="margin-top: 16px;">
          {entry.data.tags.map((tag) => (
            <span class="tag">{tag}</span>
          ))}
        </div>
      )}
    </div>

    <div class="article-body">
      <Content />
    </div>
  </div>
</BaseLayout>
