---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const entries = await getCollection('works', ({ data }) => {
  return data.draft !== true;
});

const sortedEntries = entries.sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<BaseLayout title="Works" description="作品の一覧">
  <div class="page-heading">
    <h1>Works</h1>
    <p>{sortedEntries.length} works</p>
  </div>

  <div class="works-grid">
    {sortedEntries.map((entry) => (
      <a
        href={`/works/${entry.id.replace(/\.md$/, '')}/`}
        class="works-card"
      >
        <p class="works-card-date">
          {entry.data.date.toLocaleDateString('ja-JP')}
        </p>
        <h2 class="works-card-title">{entry.data.title}</h2>
        {entry.data.description && (
          <p class="works-card-description">{entry.data.description}</p>
        )}
        {entry.data.tags.length > 0 && (
          <div class="works-card-tags">
            {entry.data.tags.map((tag) => (
              <span class="tag">{tag}</span>
            ))}
          </div>
        )}
      </a>
    ))}
  </div>
</BaseLayout>
