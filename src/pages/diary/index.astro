---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const entries = await getCollection('diary', ({ data }) => {
  return data.draft !== true;
});

const sortedEntries = entries.sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<BaseLayout title="Diary" description="日記の一覧">
  <div class="page-heading">
    <h1>Diary</h1>
    <p>{sortedEntries.length} entries</p>
  </div>

  <ul class="diary-list">
    {sortedEntries.map((entry) => (
      <li class="diary-item">
        <time class="diary-date" datetime={entry.data.date.toISOString()}>
          {entry.data.date.toLocaleDateString('ja-JP')}
        </time>
        <div class="diary-content">
          <a
            href={`/diary/${entry.id.replace(/\.md$/, '')}/`}
            class="diary-title-link"
          >
            {entry.data.title}
          </a>
          {entry.data.description && (
            <p class="diary-description">{entry.data.description}</p>
          )}
        </div>
      </li>
    ))}
  </ul>
</BaseLayout>
