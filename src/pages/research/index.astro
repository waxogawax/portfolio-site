---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Research" description="研究・調査活動の記録">
  <div class="article-container">

    <p class="research-statement">
      キュレーター・研究者。<br />
      展示、批評、制作を横断しながら活動しています。
    </p>

    <div class="research-body">

      <section class="research-section">
        <h2 class="research-section-label">学術・研究</h2>
        <ul class="affil-list">
          <li class="affil-item">
            <span class="affil-org">慶應義塾大学大学院 政策・メディア研究科</span>
            <span class="affil-role">後期博士課程在籍中</span>
          </li>
          <li class="affil-item">
            <span class="affil-org">人間文化機構 総合地球環境学研究所</span>
            <span class="affil-role">共同研究員</span>
          </li>
          <li class="affil-item">
            <span class="affil-org">科学技術振興機構（JST）次世代研究者挑戦的研究プログラム</span>
            <span class="affil-role">フェロー</span>
          </li>
        </ul>
      </section>

      <section class="research-section">
        <h2 class="research-section-label">事業・法人</h2>
        <ul class="affil-list">
          <li class="affil-item">
            <span class="affil-org">株式会社 金丸商店</span>
            <span class="affil-role">共同代表</span>
          </li>
          <li class="affil-item">
            <span class="affil-org">一般社団法人 HERO's Lab</span>
            <span class="affil-role">共同理事</span>
          </li>
        </ul>
      </section>

      <section class="research-section">
        <h2 class="research-section-label">その他</h2>
        <ul class="affil-list">
          <li class="affil-item">
            <span class="affil-org">一般社団法人 6okken</span>
            <span class="affil-role">R&amp;Dメンバー</span>
          </li>
          <li class="affil-item">
            <span class="affil-org">一般社団法人 みなとメディアミュージアム</span>
            <span class="affil-role">実行委員</span>
          </li>
        </ul>
      </section>

      <section class="research-section">
        <h2 class="research-section-label">関心領域</h2>
        <ul class="research-topics">
          <li>デザイン批評・デザイン史</li>
          <li>メディア論・視覚文化</li>
          <li>展示論・キュレーション実践</li>
        </ul>
      </section>

      <section class="research-section">
        <h2 class="research-section-label">Academic Profile</h2>
        <p class="research-text">researchmap にて業績一覧を公開しています。</p>
        <a
          href="https://researchmap.jp/waxogawa"
          class="research-external-link"
          target="_blank"
          rel="noopener noreferrer"
        >
          researchmap ↗
        </a>
      </section>

      <section class="research-section">
        <h2 class="research-section-label">Publications</h2>
        <p class="research-text research-placeholder">準備中です。</p>
      </section>

    </div>
  </div>
</BaseLayout>

<style>
  .research-statement {
    font-family: var(--font-serif);
    font-size: 1.08rem;
    line-height: 2.0;
    color: var(--color-text);
    max-width: 560px;
    padding-bottom: 52px;
    margin-bottom: 52px;
    border-bottom: 1px solid var(--color-border);
  }

  .research-body {
    display: flex;
    flex-direction: column;
    gap: 48px;
  }

  .research-section-label {
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-muted);
    margin-bottom: 0;
    padding-bottom: 10px;
    border-bottom: 1px solid var(--color-border);
  }

  .affil-list {
    list-style: none;
    display: flex;
    flex-direction: column;
  }

  .affil-item {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 20px;
    padding: 12px 0;
    border-bottom: 1px solid var(--color-border);
  }

  .affil-org {
    font-size: 0.90rem;
    color: var(--color-text);
    line-height: 1.55;
  }

  .affil-role {
    font-size: 0.80rem;
    color: var(--color-muted);
    flex-shrink: 0;
    text-align: right;
    white-space: nowrap;
  }

  .research-topics {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding-top: 16px;
  }

  .research-topics li {
    font-size: 0.92rem;
    color: var(--color-text);
    padding-left: 1.2em;
    position: relative;
  }

  .research-topics li::before {
    content: '–';
    position: absolute;
    left: 0;
    color: var(--color-muted);
  }

  .research-text {
    font-size: 0.92rem;
    color: var(--color-muted);
    line-height: 1.7;
    margin-bottom: 14px;
    padding-top: 14px;
  }

  .research-placeholder {
    font-style: italic;
  }

  .research-external-link {
    font-size: 0.88rem;
    color: var(--color-text);
    letter-spacing: 0.02em;
    transition: color var(--transition);
    display: inline-block;
  }

  .research-external-link:hover {
    color: var(--color-accent);
  }

  @media (max-width: 600px) {
    .affil-item {
      flex-direction: column;
      gap: 4px;
    }
    .affil-role {
      text-align: left;
    }
  }
</style>
