---
// Turing reaction-diffusion field — decorative background.
// Canvas is position:fixed, pointer-events:none, z-index:0.
// Content sits at z-index ≥ 1.
---

<canvas class="turing-field" aria-hidden="true"></canvas>

<style>
  .turing-field {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 0;
  }
</style>

<script>
  function initTuringField() {
    const canvas = document.querySelector('.turing-field');
    if (!(canvas instanceof HTMLCanvasElement)) return;
    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const isMobile  = window.innerWidth < 768;
    const SCALE     = isMobile ? 0.25 : 0.40;
    const N         = isMobile ? 5    : 9;
    const FRAME_MS  = 1000 / 20;

    function resize() {
      canvas.width  = Math.floor(window.innerWidth  * SCALE);
      canvas.height = Math.floor(window.innerHeight * SCALE);
    }
    resize();
    window.addEventListener('resize', () => {
      resize();
      if (prefersReduced || isMobile) draw(performance.now());
    }, { passive: true });

    // Particles biased to hero+grid zone (y 0.35–0.85)
    const pts = Array.from({ length: N }, () => ({
      x:     0.05 + Math.random() * 0.90,
      y:     0.35 + Math.random() * 0.50,
      vx:    (Math.random() - 0.5) * 0.00006,
      vy:    (Math.random() - 0.5) * 0.00006,
      r:     0.26 + Math.random() * 0.20,
      phase: Math.random() * Math.PI * 2,
      conc:  Math.random(),
    }));

    function update(dt) {
      const W = canvas.width, H = canvas.height;
      for (let i = 0; i < N; i++) {
        const p = pts[i];
        p.x += p.vx * dt;
        p.y += p.vy * dt;

        if (p.x < 0.05) p.vx += 0.000003 * dt;
        if (p.x > 0.95) p.vx -= 0.000003 * dt;
        if (p.y < 0.08) p.vy += 0.000003 * dt;
        if (p.y > 0.92) p.vy -= 0.000003 * dt;

        // Attractor at y≈0.60 (centre of grid area)
        p.vy += 0.0000008 * dt * (0.60 - p.y);
        p.phase += 0.0004 * dt;

        let inhibition = 0;
        for (let j = 0; j < N; j++) {
          if (j === i) continue;
          const dx   = (pts[j].x - p.x) * W;
          const dy   = (pts[j].y - p.y) * H;
          const dist = Math.sqrt(dx * dx + dy * dy);
          const iR   = W * 0.42;
          if (dist < iR) inhibition += pts[j].conc * (1 - dist / iR);
        }

        const rate = 0.00015 * dt;
        p.conc += rate * (1 - p.conc)
                - rate * 2.0 * inhibition
                + (Math.random() - 0.5) * 0.0002 * dt;
        p.conc = Math.max(0.04, Math.min(1, p.conc));
      }
    }

    // Temporary activation pulses triggered by .index-item mouseenter
    let activations = [];

    function draw(now) {
      const W = canvas.width, H = canvas.height;
      ctx.clearRect(0, 0, W, H);

      // Continuous base wash across the grid zone
      const fieldGrd = ctx.createLinearGradient(0, H * 0.20, 0, H * 0.92);
      fieldGrd.addColorStop(0,    'rgba(255,255,0,0)');
      fieldGrd.addColorStop(0.15, 'rgba(255,255,0,0.016)');
      fieldGrd.addColorStop(0.50, 'rgba(255,255,0,0.026)');
      fieldGrd.addColorStop(0.85, 'rgba(255,255,0,0.016)');
      fieldGrd.addColorStop(1,    'rgba(255,255,0,0)');
      ctx.fillStyle = fieldGrd;
      ctx.fillRect(0, 0, W, H);

      // Particle halos — large radius, low alpha → smooth blended field
      for (const p of pts) {
        const px     = p.x * W, py = p.y * H;
        const pulse  = 0.88 + 0.12 * Math.sin(p.phase);
        const outerR = p.r * W * pulse;
        const alpha  = p.conc * 0.065;

        const og = ctx.createRadialGradient(px, py, 0, px, py, outerR);
        og.addColorStop(0,    `rgba(255,255,0,${alpha.toFixed(4)})`);
        og.addColorStop(0.40, `rgba(255,255,0,${(alpha * 0.30).toFixed(4)})`);
        og.addColorStop(1,    'rgba(255,255,0,0)');
        ctx.fillStyle = og;
        ctx.beginPath();
        ctx.arc(px, py, outerR, 0, Math.PI * 2);
        ctx.fill();

        if (p.conc > 0.28) {
          const innerR = p.r * W * 0.28 * pulse;
          const ia     = (p.conc - 0.28) * 0.09;
          const ig = ctx.createRadialGradient(px, py, 0, px, py, innerR);
          ig.addColorStop(0, `rgba(255,255,0,${ia.toFixed(4)})`);
          ig.addColorStop(1, 'rgba(255,255,0,0)');
          ctx.fillStyle = ig;
          ctx.beginPath();
          ctx.arc(px, py, innerR, 0, Math.PI * 2);
          ctx.fill();
        }
      }

      // Activation pulses: expand and fade over ~2.2 s
      activations = activations.filter(a => now - a.born < a.life);
      for (const a of activations) {
        const t     = (now - a.born) / a.life;
        const fade  = 0.5 * (1 + Math.cos(Math.PI * t));  // cosine ease-out 1→0
        const R     = (0.07 + t * 0.13) * W;               // expands as it fades
        const alpha = fade * 0.22;
        const px    = a.x * W, py = a.y * H;

        const ag = ctx.createRadialGradient(px, py, 0, px, py, R);
        ag.addColorStop(0,    `rgba(255,255,0,${alpha.toFixed(4)})`);
        ag.addColorStop(0.45, `rgba(255,255,0,${(alpha * 0.28).toFixed(4)})`);
        ag.addColorStop(1,    'rgba(255,255,0,0)');
        ctx.fillStyle = ag;
        ctx.beginPath();
        ctx.arc(px, py, R, 0, Math.PI * 2);
        ctx.fill();
      }
    }

    // Pre-warm: 500 virtual frames so pattern is stable at first render
    for (let i = 0; i < 500; i++) update(16);

    if (prefersReduced || isMobile) {
      draw(performance.now());
      return;
    }

    // Mouseenter activation (desktop + motion-OK only)
    document.querySelectorAll('.index-item').forEach(el => {
      el.addEventListener('mouseenter', () => {
        const rect = el.getBoundingClientRect();
        activations.push({
          x:    (rect.left + rect.width  * 0.5) / window.innerWidth,
          y:    (rect.top  + rect.height * 0.5) / window.innerHeight,
          born: performance.now(),
          life: 2200,
        });
        if (activations.length > 4) activations.shift();
      });
    });

    let lastTime = null;
    const tick = (now) => {
      if (lastTime !== null && now - lastTime < FRAME_MS) {
        requestAnimationFrame(tick);
        return;
      }
      const dt = lastTime === null ? 16 : Math.min(now - lastTime, 60);
      lastTime = now;
      update(dt);
      draw(now);
      requestAnimationFrame(tick);
    };
    requestAnimationFrame(tick);
  }

  initTuringField();
</script>
